{
    "name": "novotonbun/dev-tooling",
    "description": "Dev-only tooling for the NovotonBUN monorepo (three CS-Cart addons). Never deployed.",
    "type": "project",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "phpro/grumphp": "^2.7",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.0",
        "spaze/phpstan-disallowed-calls": "^4.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpro/grumphp": false
        },
        "platform": {
            "php": "8.3.0"
        }
    },
    "scripts": {
        "post-install-cmd": "@php -r \"is_dir('var') || mkdir('var', 0755, true);\"",
        "post-update-cmd":  "@php -r \"is_dir('var') || mkdir('var', 0755, true);\"",

        "hooks:install":   "grumphp git:init",
        "hooks:uninstall": "grumphp git:deinit",

        "stan": "phpstan analyse --memory-limit=1G",
        "stan:baseline": "phpstan analyse --memory-limit=1G --generate-baseline=phpstan-baseline.neon --allow-empty-baseline",

        "fix": "php-cs-fixer fix",
        "fix:dry": "php-cs-fixer fix --dry-run --diff",

        "rector:dry": "rector process --dry-run --no-progress-bar",
        "rector:fix": "rector process --no-progress-bar",

        "test:novoton":     "cd addon-novoton-holidays/app/addons/novoton_holidays && vendor/bin/phpunit --no-coverage",
        "test:travel-core": "cd addon-travel-core/app/addons/travel_core && vendor/bin/phpunit --no-coverage",
        "test:sphinx":      "cd addon-sphinx-holidays/app/addons/sphinx_holidays && vendor/bin/phpunit --no-coverage",
        "test:fgo":         "cd addon-fgo-invoicing/app/addons/fgo_invoicing && vendor/bin/phpunit --no-coverage",
        "test": [
            "@test:novoton",
            "@test:travel-core",
            "@test:sphinx",
            "@test:fgo"
        ],

        "test:integration:novoton": "cd addon-novoton-holidays/app/addons/novoton_holidays && vendor/bin/phpunit -c phpunit-integration.xml --no-coverage",

        "check": [
            "@stan",
            "@fix:dry",
            "@rector:dry",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "stan":          "PHPStan static analysis (level 10)",
        "stan:baseline": "Regenerate PHPStan baseline from current errors",
        "fix":           "PHP CS Fixer — auto-format code",
        "fix:dry":       "PHP CS Fixer — show what would change (dry run)",
        "rector:dry":    "Rector — show what would change (dry run, fails on drift)",
        "rector:fix":    "Rector — apply refactoring rules (see rector.php)",
        "test:novoton":     "PHPUnit tests for the novoton_holidays addon",
        "test:travel-core": "PHPUnit tests for the travel_core addon",
        "test:sphinx":      "PHPUnit tests for the sphinx_holidays addon",
        "test:fgo":         "PHPUnit tests for the fgo_invoicing addon",
        "test":             "Run PHPUnit across all addon suites",
        "test:integration:novoton": "Run novoton DB-backed integration tests (requires docker-compose.test.yml up)",
        "check":         "Run PHPStan + CS Fixer dry-run + Rector dry-run + PHPUnit"
    }
}

{
    "general": {
        "fields": {
            "full_width": {
                "description": "theme_editor.full_width",
                "type": "checkbox",
                "true": "true",
                "false": "false"
            }
        }
    },
    "colors": {
        "fields": {
            "main_color": {
                "description": "theme_editor.main_color"
            },
            "secondary_color": {
                "description": "theme_editor.secondary_color"
            },
            "links_color": {
                "description": "theme_editor.links_color"
            },
            "top_menu_bg": {
                "description": "theme_editor.top_menu_bg"
            },
            "top_menu_color": {
                "description": "theme_editor.top_menu_color"
            },
            "header_bottom_bg": {
                "description": "theme_editor.header_bottom_bg"
            },
            "footer_bg": {
                "description": "theme_editor.footer_bg"
            },
            "footer_color": {
                "description": "theme_editor.footer_color"
            },
            "novoton-primary": {
                "description": "theme_editor.novoton_primary_color"
            },
            "novoton-accent": {
                "description": "theme_editor.novoton_accent_color"
            },
            "novoton-search-btn-bg": {
                "description": "theme_editor.novoton_search_btn_color"
            },
            "novoton-search-btn-hover": {
                "description": "theme_editor.novoton_search_btn_hover_color"
            },
            "novoton-text": {
                "description": "theme_editor.novoton_text_color"
            },
            "novoton-bg": {
                "description": "theme_editor.novoton_bg_color"
            },
            "novoton-border": {
                "description": "theme_editor.novoton_border_color"
            },
            "novoton-success": {
                "description": "theme_editor.novoton_success_color"
            },
            "novoton-danger": {
                "description": "theme_editor.novoton_danger_color"
            }
        }
    },
    "fonts": {
        "families": [
            "Arial, Helvetica, sans-serif",
            "Georgia, 'Times New Roman', Times, serif",
            "'Courier New', Courier, monospace",
            "Tahoma, Geneva, sans-serif",
            "Verdana, Geneva, sans-serif",
            "'Trebuchet MS', Helvetica, sans-serif",
            "Impact, Charcoal, sans-serif",
            "'Lucida Console', Monaco, monospace"
        ],
        "fields": {
            "base_font": {
                "description": "theme_editor.base_font",
                "properties": {
                    "size": {
                        "match": "base-font-size-value",
                        "unit": "px",
                        "values": [11, 12, 13, 14, 15, 16]
                    },
                    "style": {
                        "B": {
                            "match": "base-font-weight",
                            "property": "font-weight",
                            "default": "normal"
                        }
                    }
                }
            },
            "novoton-font-family": {
                "description": "theme_editor.novoton_base_font",
                "properties": {
                    "size": {
                        "match": "novoton-font-size-base-value",
                        "unit": "px",
                        "values": [11, 12, 13, 14, 15, 16]
                    },
                    "style": {
                        "B": {
                            "match": "novoton-font-weight",
                            "property": "font-weight",
                            "default": "normal"
                        }
                    }
                }
            }
        }
    },
    "backgrounds": {
        "fields": {
            "body_bg": {
                "description": "theme_editor.body_bg",
                "properties": {
                    "color": {
                        "match": "bg_color"
                    },
                    "pattern": "body_bg_pattern",
                    "repeat": "body_bg_repeat"
                },
                "transparent": {
                    "match": "body_bg_transparent"
                }
            },
            "novoton-page-bg": {
                "description": "theme_editor.novoton_page_background",
                "properties": {
                    "color": {
                        "match": "novoton-bg"
                    },
                    "pattern": "novoton-bg-pattern",
                    "repeat": "novoton-bg-repeat"
                },
                "transparent": {
                    "match": "novoton-bg-transparent"
                }
            }
        }
    }
}

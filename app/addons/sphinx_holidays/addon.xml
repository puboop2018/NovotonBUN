<?xml version="1.0"?>
<addon scheme="3.0">
    <id>sphinx_holidays</id>
    <version>1.0.0</version>
    <priority>112</priority>
    <position>2</position>
    <status>active</status>
    <supplier>VacanteLitoral.ro</supplier>
    <supplier_link>https://vacantelitoral.ro</supplier_link>
    <default_language>en</default_language>
    <dependencies>travel_core</dependencies>
    <!-- Sphinx Holidays: hotel & package booking integration with Sphinx REST API
         (Christian Tour). Supports hotel-only search, flight+hotel packages,
         bus+hotel packages, circuits, and experiences.
         Requires PHP 8.3+ and travel_core addon. -->

    <authors>
        <author>
            <name>VacanteLitoral.ro</name>
            <email>office@VacanteLitoral.ro</email>
            <url>https://vacantelitoral.ro</url>
        </author>
    </authors>

    <compatibility>
        <core_version>
            <min>4.9.3</min>
            <max>4.20.1</max>
        </core_version>
        <core_edition>ULTIMATE</core_edition>
        <php_version>
            <min>8.3.0</min>
            <max>8.4.99</max>
        </php_version>
        <php_extensions>
            <curl>
                <supported>Y</supported>
            </curl>
            <json>
                <supported>Y</supported>
            </json>
        </php_extensions>
    </compatibility>

    <settings layout="separate">

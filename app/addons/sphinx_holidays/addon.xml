                    </item>
                    <item id="api_key">
                        <type>password</type>
                        <default_value></default_value>
                        <variants/>
                    </item>
                    <item id="enable_api_cache">
                        <type>checkbox</type>
                        <default_value>Y</default_value>
                        <variants/>
                    </item>
                    <item id="cache_ttl_search">
                        <type>input</type>
                        <default_value>300</default_value>
                        <variants/>
                    </item>

                    <!-- Search Settings Header -->
                    <item id="search_header">
                        <type>header</type>
                        <variants/>
                    </item>
                    <item id="default_currency">
                        <type>selectbox</type>
                        <default_value>EUR</default_value>
                        <variants>
                            <item id="EUR">EUR</item>
                            <item id="RON">RON</item>
                            <item id="USD">USD</item>
                            <item id="GBP">GBP</item>
                        </variants>
                    </item>
                    <item id="ignore_domains">
                        <type>input</type>
                        <default_value></default_value>
                        <variants/>
                    </item>
                    <item id="search_poll_interval">
                        <type>input</type>
                        <default_value>2</default_value>
                        <variants/>
                    </item>
                    <item id="search_max_polls">
                        <type>input</type>
                        <default_value>30</default_value>
                        <variants/>
                    </item>

                    <!-- Pricing Header -->
                    <item id="pricing_header">
                        <type>header</type>
                        <variants/>
                    </item>
                    <item id="commission">
                        <type>input</type>
                        <default_value>0</default_value>
                        <variants/>
                    </item>
                    <item id="round_prices">
                        <type>checkbox</type>
                        <default_value>N</default_value>
                        <variants/>
                    </item>

                    <!-- Product Mapping Header -->
                    <item id="product_header">
                        <type>header</type>
                        <variants/>
                    </item>
                    <item id="hotels_category_id">
                        <type>input</type>
                        <default_value>0</default_value>
                        <variants/>
                    </item>
                    <item id="packages_category_id">
                        <type>input</type>
                        <default_value>0</default_value>
                        <variants/>
                    </item>
                    <item id="product_category_template">
                        <type>input</type>
                        <default_value>Hotels/{country}/{region}/{city}</default_value>
                        <variants/>
                    </item>

                    <!-- API Resilience Header -->
                    <item id="resilience_header">
                        <type>header</type>
                        <variants/>
                    </item>
                    <item id="api_max_retries">
                        <type>input</type>
                        <default_value>3</default_value>
                        <variants/>
                    </item>
                    <item id="api_retry_delay_ms">
                        <type>input</type>
                        <default_value>500</default_value>
                        <variants/>
                    </item>
                    <item id="api_retry_multiplier">
                        <type>input</type>
                        <default_value>2</default_value>
                        <variants/>
                    </item>
                    <item id="circuit_breaker_threshold">
                        <type>input</type>
                        <default_value>5</default_value>
                        <variants/>
                    </item>
                    <item id="circuit_breaker_timeout">
                        <type>input</type>
                        <default_value>60</default_value>
                        <variants/>
                    </item>

                    <!-- Hotel Sync Header -->
                    <item id="hotel_sync_header">
                        <type>header</type>
                        <variants/>
                    </item>
                    <item id="selected_destinations">
                        <type>textarea</type>
                        <default_value>GR</default_value>
                        <variants/>
                    </item>

                    <!-- Cron Header -->
                    <item id="cron_header">
                        <type>header</type>
                        <variants/>
                    </item>
                    <item id="cron_access_key">
                        <type>password</type>
                        <default_value></default_value>
                        <variants/>
                    </item>

                    <!-- Debug Header -->
                    <item id="debug_header">
                        <type>header</type>
                        <variants/>
                    </item>
                    <item id="debug_logging">
                        <type>checkbox</type>
                        <default_value>N</default_value>
                        <variants/>
                    </item>
                </items>
            </section>
        </sections>

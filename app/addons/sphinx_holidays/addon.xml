    <queries>
        <!-- Sphinx hotels (local cache of static hotel data) -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:sphinx_hotels` (
                `hotel_id`          VARCHAR(100) NOT NULL PRIMARY KEY COMMENT 'Sphinx hotel ID (e.g. s1-hotel-123)',
                `product_id`        INT UNSIGNED DEFAULT NULL COMMENT 'FK to ?:products',
                `name`              VARCHAR(255) NOT NULL,
                `classification`    TINYINT UNSIGNED DEFAULT NULL COMMENT 'Star rating 1-5',
                `property_type`     VARCHAR(30) DEFAULT 'hotel',
                `destination_id`    INT UNSIGNED DEFAULT NULL,
                `destination_name`  VARCHAR(255) DEFAULT NULL,
                `region_id`         INT UNSIGNED DEFAULT NULL,
                `region_name`       VARCHAR(255) DEFAULT NULL,
                `country_code`      VARCHAR(5) DEFAULT NULL,
                `country_name`      VARCHAR(255) DEFAULT NULL,
                `latitude`          DECIMAL(10,7) DEFAULT NULL,
                `longitude`         DECIMAL(10,7) DEFAULT NULL,
                `description`       TEXT DEFAULT NULL,
                `short_description` TEXT DEFAULT NULL,
                `image_url`         VARCHAR(500) DEFAULT NULL,
                `amenities_json`    JSON DEFAULT NULL COMMENT 'Array of amenity objects',
                `tags_json`         JSON DEFAULT NULL COMMENT 'Array of tag objects',
                `facilities_json`   JSON DEFAULT NULL COMMENT 'Array of facility objects from static endpoint',
                `is_recommended`    ENUM('Y','N') DEFAULT 'N',
                `is_adults_only`    ENUM('Y','N') DEFAULT 'N',
                `rating`            DECIMAL(3,1) DEFAULT NULL COMMENT 'Guest rating (e.g. 8.5)',
                `rating_count`      INT UNSIGNED DEFAULT NULL,
                `sync_status`       ENUM('active','inactive','error') DEFAULT 'active',
                `last_synced_at`    DATETIME DEFAULT NULL,
                `created_at`        DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                `updated_at`        DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
                KEY `idx_product_id` (`product_id`),
                KEY `idx_destination` (`destination_id`),
                KEY `idx_region` (`region_id`),
                KEY `idx_country` (`country_code`),
                KEY `idx_classification` (`classification`),
                KEY `idx_sync_status` (`sync_status`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>

        <!-- Sphinx destinations (cached destination tree) -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:sphinx_destinations` (
                `destination_id`    INT UNSIGNED NOT NULL PRIMARY KEY,
                `name`              VARCHAR(255) NOT NULL,
                `type`              VARCHAR(30) NOT NULL COMMENT 'continent, country, region, city, destination',
                `parent_id`         INT UNSIGNED DEFAULT NULL,
                `country_code`      VARCHAR(5) DEFAULT NULL,
                `full_path`         VARCHAR(500) DEFAULT NULL COMMENT 'Breadcrumb: City, Region, Country, Continent',
                `geoname_id`        INT UNSIGNED DEFAULT NULL,
                `latitude`          DECIMAL(10,7) DEFAULT NULL,
                `longitude`         DECIMAL(10,7) DEFAULT NULL,
                `hotel_count`       INT UNSIGNED DEFAULT 0,
                `last_synced_at`    DATETIME DEFAULT NULL,
                KEY `idx_type` (`type`),
                KEY `idx_parent` (`parent_id`),
                KEY `idx_country` (`country_code`),
                KEY `idx_full_path` (`full_path`(100)),
                KEY `idx_geoname` (`geoname_id`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>

        <!-- Sphinx package routes (cached flight/bus routes) -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:sphinx_package_routes` (
                `route_id`          INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
                `transport_type`    VARCHAR(10) NOT NULL COMMENT 'flight, bus',
                `departure_id`      INT UNSIGNED NOT NULL,
                `departure_name`    VARCHAR(255) NOT NULL,
                `departure_iata`    VARCHAR(10) DEFAULT NULL,
                `arrival_id`        INT UNSIGNED NOT NULL,
                `arrival_name`      VARCHAR(255) NOT NULL,
                `arrival_iata`      VARCHAR(10) DEFAULT NULL,
                `available_dates`   JSON NOT NULL COMMENT 'Array of date strings',
                `duration`          TINYINT UNSIGNED NOT NULL COMMENT 'Number of nights',
                `last_synced_at`    DATETIME DEFAULT NULL,
                UNIQUE KEY `uq_route` (`transport_type`, `departure_id`, `arrival_id`, `duration`),
                KEY `idx_departure` (`departure_id`),
                KEY `idx_arrival` (`arrival_id`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>

        <!-- Sphinx bookings (provider-specific booking data, mirrors novoton_bookings pattern) -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:sphinx_bookings` (
                `booking_id`        INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
                `order_id`          INT UNSIGNED NOT NULL DEFAULT 0,
                `user_id`           INT UNSIGNED NOT NULL DEFAULT 0,
                `session_id`        VARCHAR(64) DEFAULT NULL,
                `product_id`        INT UNSIGNED NOT NULL DEFAULT 0,
                `hotel_id`          VARCHAR(100) DEFAULT NULL,
                `hotel_name`        VARCHAR(255) DEFAULT NULL,
                `offer_id`          VARCHAR(255) DEFAULT NULL COMMENT 'Original offer ID',
                `room_id`           VARCHAR(100) DEFAULT NULL,
                `room_type`         VARCHAR(255) DEFAULT NULL,
                `board_id`          VARCHAR(100) DEFAULT NULL,
                `check_in`          DATE DEFAULT NULL,
                `check_out`         DATE DEFAULT NULL,
                `nights`            SMALLINT UNSIGNED DEFAULT 0,
                `adults`            TINYINT UNSIGNED DEFAULT 2,
                `children`          TINYINT UNSIGNED DEFAULT 0,
                `children_ages`     VARCHAR(100) DEFAULT NULL,
                `num_rooms`         TINYINT UNSIGNED DEFAULT 1,
                `rooms_data`        JSON DEFAULT NULL,
                `guest_name`        VARCHAR(500) DEFAULT NULL,
                `holder_name`       VARCHAR(255) DEFAULT NULL,
                `guest_email`       VARCHAR(255) DEFAULT NULL,
                `guest_phone`       VARCHAR(100) DEFAULT NULL,
                `guests_data`       JSON DEFAULT NULL,
                `base_price`        DECIMAL(10,2) DEFAULT 0.00,
                `total_price`       DECIMAL(10,2) DEFAULT 0.00,
                `currency`          VARCHAR(3) DEFAULT 'EUR',
                `status`            VARCHAR(30) DEFAULT 'pending',
                `api_booking_ref`   VARCHAR(100) DEFAULT NULL COMMENT 'Booking reference from Sphinx API',
                `api_response`      JSON DEFAULT NULL COMMENT 'Full API response JSON',
                `created_at`        DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                `updated_at`        DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
                KEY `idx_order_id` (`order_id`),
                KEY `idx_user_session` (`user_id`, `session_id`),
                KEY `idx_hotel` (`hotel_id`),
                KEY `idx_status` (`status`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>

        <!-- Sphinx sync log -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:sphinx_sync_log` (
                `log_id`        INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
                `sync_type`     VARCHAR(50) NOT NULL COMMENT 'destinations, hotels, routes, full',
                `status`        ENUM('started','completed','failed') NOT NULL,
                `items_total`   INT UNSIGNED DEFAULT 0,
                `items_synced`  INT UNSIGNED DEFAULT 0,
                `items_failed`  INT UNSIGNED DEFAULT 0,
                `error_message` TEXT DEFAULT NULL,
                `rate_limit_hits` INT UNSIGNED DEFAULT 0,
                `sync_mode`     VARCHAR(20) DEFAULT 'full' COMMENT 'full or incremental',
                `duration_ms`   INT UNSIGNED DEFAULT NULL,
                `started_at`    DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
                `completed_at`  DATETIME DEFAULT NULL,
                KEY `idx_type_status` (`sync_type`, `status`),
                KEY `idx_started` (`started_at`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>

        <!-- Sphinx API cache -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:sphinx_cache` (
                `cache_key`     VARCHAR(255) NOT NULL PRIMARY KEY,
                `cache_data`    LONGBLOB NOT NULL,
                `expires_at`    INT UNSIGNED NOT NULL COMMENT 'Unix timestamp',
                KEY `idx_expires` (`expires_at`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>
        <!-- Upgrade: add full_path column to existing sphinx_destinations -->
        <item for="upgrade">
            ALTER TABLE `?:sphinx_destinations`
                ADD COLUMN IF NOT EXISTS `full_path` VARCHAR(500) DEFAULT NULL COMMENT 'Breadcrumb: City, Region, Country, Continent'
                AFTER `country_code`;
        </item>
        <item for="upgrade">
            ALTER TABLE `?:sphinx_destinations`
                ADD KEY `idx_full_path` (`full_path`(100));
        </item>
        <!-- Upgrade: add rate_limit_hits column to sphinx_sync_log -->
        <item for="upgrade">
            ALTER TABLE `?:sphinx_sync_log`
                ADD COLUMN IF NOT EXISTS `rate_limit_hits` INT UNSIGNED DEFAULT 0 AFTER `error_message`;
        </item>
        <!-- Upgrade: add sync_mode column to sphinx_sync_log -->
        <item for="upgrade">
            ALTER TABLE `?:sphinx_sync_log`
                ADD COLUMN IF NOT EXISTS `sync_mode` VARCHAR(20) DEFAULT 'full' AFTER `rate_limit_hits`;
        </item>
    </queries>


<?xml version="1.0"?>
<psalm
    errorLevel="5"
    resolveFromConfigFile="true"
    findUnusedBaselineEntry="false"
    findUnusedCode="false"
    errorBaseline="psalm-baseline.xml"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    cacheDirectory="var/psalm-cache"
>
    <!--
      Psalm level 5 is middle-ground (1=strictest, 8=loosest). Used alongside
      PHPStan level 10 as a second opinion — each tool catches different issues:
        - Psalm is better at: immutability, impure function detection, taint analysis
        - PHPStan is better at: union type narrowing, class-level rules, generics

      Baseline driven once with the set-baseline command; all new code must pass clean.
    -->

    <projectFiles>
        <directory name="addon-novoton-holidays/app/addons/novoton_holidays/src" />
        <directory name="addon-travel-core/app/addons/travel_core/src" />
        <directory name="addon-sphinx-holidays/app/addons/sphinx_holidays/src" />

        <ignoreFiles>
            <directory name="vendor" />
            <directory name="var" />
            <directory name="addon-novoton-holidays/app/addons/novoton_holidays/tests" />
        </ignoreFiles>
    </projectFiles>

    <!--
      CS-Cart ships global procedural functions (fn_*, db_*, __) and class
      aliases (\Tygh\Registry, \Tygh\Tygh) that Psalm cannot resolve without
      stubs. Silence those categories since we can't realistically stub all of
      CS-Cart.
    -->
    <issueHandlers>
        <UndefinedFunction errorLevel="suppress"/>
        <UndefinedClass errorLevel="suppress"/>
        <UndefinedConstant errorLevel="suppress"/>
        <UndefinedDocblockClass errorLevel="suppress"/>
        <UndefinedMagicMethod errorLevel="suppress"/>
        <UndefinedMagicPropertyFetch errorLevel="suppress"/>
        <UndefinedMethod errorLevel="suppress"/>
        <UndefinedPropertyFetch errorLevel="suppress"/>
        <UndefinedPropertyAssignment errorLevel="suppress"/>
        <UndefinedThisPropertyFetch errorLevel="suppress"/>
    </issueHandlers>
</psalm>

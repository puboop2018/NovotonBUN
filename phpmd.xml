<?xml version="1.0"?>
<ruleset name="NovotonBUN"
         xmlns="http://pmd.sf.net/ruleset/1.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sf.net/ruleset/1.0.0 http://pmd.sf.net/ruleset_xml_schema.xsd"
         xsi:noNamespaceSchemaLocation="http://pmd.sf.net/ruleset_xml_schema.xsd">

    <description>
        PHPMD ruleset for the NovotonBUN monorepo.

        Focused on actionable issues: unused code + design smells.
        Excluded: cleancode (too opinionated for legacy), controversial,
        codesize complexity metrics (CS-Cart controllers naturally have
        high complexity from mode-dispatch patterns).
    </description>

    <!-- ── Unused Code (high-value signal) ──────────────────────────── -->
    <rule ref="rulesets/unusedcode.xml">
        <!-- CS-Cart hooks have fixed signatures; unused params are mandatory -->
        <exclude name="UnusedFormalParameter"/>
    </rule>

    <!-- ── Design smells ─────────────────────────────────────────────── -->
    <rule ref="rulesets/design.xml">
        <exclude name="CouplingBetweenObjects"/>
        <exclude name="NumberOfChildren"/>
        <!-- CountInLoop can give false positives on small finite loops -->
        <exclude name="CountInLoop"/>
    </rule>

    <!-- ── Naming (basics only) ──────────────────────────────────────── -->
    <rule ref="rulesets/naming.xml/ConstantNamingConventions"/>
    <rule ref="rulesets/naming.xml/ConstructorWithNameAsEnclosingClass"/>
    <rule ref="rulesets/naming.xml/BooleanGetMethodName"/>

    <!--
      NOT included:
        codesize.xml  — complexity thresholds trigger on legitimate dispatchers
        cleancode.xml — static access, else-expression, etc. don't fit legacy code
        controversial.xml — Camel vs snake_case wars
    -->
</ruleset>

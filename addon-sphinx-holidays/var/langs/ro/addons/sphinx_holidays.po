msgctxt "SettingsSections::sphinx_holidays::general"
msgid "General"
msgstr "General"

msgctxt "SettingsSections::sphinx_holidays::seo_templates"
msgid "SEO Templates"
msgstr "Șabloane SEO"

msgctxt "Addons::name::sphinx_holidays"
msgid "Sphinx Holidays"
msgstr "Sphinx Holidays"

msgctxt "Addons::description::sphinx_holidays"
msgid "Sphinx REST API integration for hotel, package, circuit and experience bookings. Provides search, availability, pricing, booking and destination sync via the Sphinx travel platform."
msgstr "Integrare API REST Sphinx pentru rezervări de hoteluri, pachete, circuite și experiențe. Oferă căutare, disponibilitate, prețuri, rezervări și sincronizare destinații prin platforma de turism Sphinx."

msgctxt "Languages::sphinx_holidays.search_error"
msgid "An error occurred while searching. Please try again later."
msgstr "A apărut o eroare la căutare. Vă rugăm încercați din nou."

msgctxt "Languages::sphinx_holidays.no_results"
msgid "No hotels found for your search criteria. Please try different dates or destination."
msgstr "Nu s-au găsit hoteluri pentru criteriile dvs. Încercați alte date sau altă destinație."

msgctxt "Languages::sphinx_holidays.search_results"
msgid "[count] results found"
msgstr "[count] rezultate găsite"

msgctxt "Languages::sphinx_holidays.search_results_title"
msgid "Hotel Search Results"
msgstr "Rezultate căutare hoteluri"

msgctxt "Languages::sphinx_holidays.book_now"
msgid "Book now"
msgstr "Rezervă acum"

msgctxt "Languages::sphinx_holidays.please_fill_required_fields"
msgid "Please fill in the required search fields."
msgstr "Vă rugăm completați câmpurile obligatorii."

msgctxt "Languages::sphinx_holidays.alternative_dates_title"
msgid "Availability found on nearby dates:"
msgstr "Disponibilitate găsită pe date apropiate:"

msgctxt "Languages::sphinx_holidays.results_found"
msgid "results"
msgstr "rezultate"

msgctxt "SettingsSections::sphinx_holidays::general"
msgid "General Settings"
msgstr "Setări Generale"

msgctxt "SettingsOptions::sphinx_holidays::api_header"
msgid "Sphinx API Settings"
msgstr "Setări API Sphinx"

msgctxt "SettingsOptions::sphinx_holidays::api_base_url"
msgid "API Base URL"
msgstr "URL bază API"

msgctxt "SettingsOptions::sphinx_holidays::api_key"
msgid "API Key (Bearer Token)"
msgstr "Cheie API (Bearer Token)"

msgctxt "SettingsOptions::sphinx_holidays::enable_api_cache"
msgid "Enable API response caching"
msgstr "Activează cache-ul răspunsurilor API"

msgctxt "SettingsOptions::sphinx_holidays::cache_ttl_search"
msgid "Search cache TTL (seconds)"
msgstr "TTL cache căutare (secunde)"

msgctxt "SettingsOptions::sphinx_holidays::search_header"
msgid "Search Settings"
msgstr "Setări Căutare"

msgctxt "SettingsOptions::sphinx_holidays::default_currency"
msgid "Default search currency"
msgstr "Monedă implicită căutare"

msgctxt "SettingsOptions::sphinx_holidays::ignore_domains"
msgid "Ignore domains (comma-separated supplier IDs to skip)"
msgstr "Domenii ignorate (ID-uri furnizori separați prin virgulă)"

msgctxt "SettingsOptions::sphinx_holidays::search_poll_interval"
msgid "Search poll interval (seconds)"
msgstr "Interval verificare căutare (secunde)"

msgctxt "SettingsOptions::sphinx_holidays::search_max_polls"
msgid "Maximum search polls before timeout"
msgstr "Număr maxim de verificări înainte de timeout"

msgctxt "SettingsOptions::sphinx_holidays::pricing_header"
msgid "Pricing"
msgstr "Prețuri"

msgctxt "SettingsOptions::sphinx_holidays::commission"
msgid "Commission percentage"
msgstr "Procentaj comision"

msgctxt "SettingsOptions::sphinx_holidays::product_header"
msgid "Product Mapping"
msgstr "Mapare Produse"

msgctxt "SettingsOptions::sphinx_holidays::hotels_category_id"
msgid "CS-Cart category ID for hotels"
msgstr "ID categorie CS-Cart pentru hoteluri"

msgctxt "SettingsTooltips::sphinx_holidays::hotels_category_id"
msgid "Root category under which hotel products are created. Country sub-categories are generated automatically."
msgstr "Categorie rădăcină pentru produse hoteliere. Sub-categoriile pe țări se creează automat."

msgctxt "SettingsOptions::sphinx_holidays::packages_category_id"
msgid "CS-Cart category ID for packages"
msgstr "ID categorie CS-Cart pentru pachete"

msgctxt "SettingsTooltips::sphinx_holidays::packages_category_id"
msgid "Root category under which package products are created. Country sub-categories are generated automatically."
msgstr "Categorie rădăcină pentru produse pachete. Sub-categoriile pe țări se creează automat."

msgctxt "SettingsOptions::sphinx_holidays::circuits_category_id"
msgid "CS-Cart category ID for circuits"
msgstr "ID categorie CS-Cart pentru circuite"

msgctxt "SettingsTooltips::sphinx_holidays::circuits_category_id"
msgid "Root category for circuit products (mapped to /api/v1/static/circuits). Country sub-categories are generated automatically."
msgstr "Categorie rădăcină pentru produse circuite (mapat la /api/v1/static/circuits). Sub-categoriile pe țări se creează automat."

msgctxt "SettingsOptions::sphinx_holidays::experiences_category_id"
msgid "CS-Cart category ID for experiences"
msgstr "ID categorie CS-Cart pentru experiențe"

msgctxt "SettingsTooltips::sphinx_holidays::experiences_category_id"
msgid "Root category for experience products (mapped to /api/v1/static/experiences). Country sub-categories are generated automatically."
msgstr "Categorie rădăcină pentru produse experiențe (mapat la /api/v1/static/experiences). Sub-categoriile pe țări se creează automat."

msgctxt "SettingsOptions::sphinx_holidays::product_languages"
msgid "Product languages"
msgstr "Limbi produse"

msgctxt "SettingsTooltips::sphinx_holidays::product_languages"
msgid "Select which CS-Cart languages to create hotel product descriptions for. Hotels will only appear in the storefront for selected languages."
msgstr "Selectați pentru care limbi CS-Cart să se creeze descrierile produselor hoteliere. Hotelurile vor apărea în magazin doar pentru limbile selectate."

msgctxt "SettingsOptions::sphinx_holidays::product_code_prefix"
msgid "Product code prefix"
msgstr "Prefix cod produs"

msgctxt "SettingsTooltips::sphinx_holidays::product_code_prefix"
msgid "Prefix added to hotel IDs to form the CS-Cart product code (e.g. SPX → SPX12345). Used to identify Sphinx hotel products."
msgstr "Prefix adăugat la ID-urile hotelurilor pentru a forma codul de produs CS-Cart (ex. SPX → SPX12345). Folosit pentru identificarea produselor hoteliere Sphinx."

msgctxt "SettingsOptions::sphinx_holidays::skip_no_description"
msgid "Skip hotels without description"
msgstr "Omite hotelurile fără descriere"

msgctxt "SettingsTooltips::sphinx_holidays::skip_no_description"
msgid "When enabled, the add_products cron will skip hotels that have no description text. This prevents creating empty product pages."
msgstr "Când este activat, cron-ul add_products va omite hotelurile care nu au text descriptiv. Previne crearea de pagini de produs goale."

msgctxt "SettingsOptions::sphinx_holidays::skip_unrated_hotels"
msgid "Skip unrated/unclassified hotels"
msgstr "Omite hotelurile fără clasificare"

msgctxt "SettingsTooltips::sphinx_holidays::skip_unrated_hotels"
msgid "When enabled (default), hotels without a star classification (0 stars) will not be imported as products. Only hotels with 1-5 stars will be added."
msgstr "Când este activat (implicit), hotelurile fără clasificare (0 stele) nu vor fi importate ca produse. Doar hotelurile cu 1-5 stele vor fi adăugate."

msgctxt "SettingsOptions::sphinx_holidays::resilience_header"
msgid "API Resilience"
msgstr "Reziliență API"

msgctxt "SettingsOptions::sphinx_holidays::api_max_retries"
msgid "Maximum retries on failure"
msgstr "Număr maxim de reîncercări"

msgctxt "SettingsTooltips::sphinx_holidays::api_max_retries"
msgid "Number of retry attempts for failed API calls (recommended: 3)"
msgstr "Numărul de reîncercări pentru apeluri API eșuate (recomandat: 3)"

msgctxt "SettingsOptions::sphinx_holidays::api_retry_delay_ms"
msgid "Initial retry delay (ms)"
msgstr "Întârziere inițială reîncercare (ms)"

msgctxt "SettingsTooltips::sphinx_holidays::api_retry_delay_ms"
msgid "Initial delay in milliseconds before first retry (recommended: 500)"
msgstr "Întârzierea inițială în milisecunde înainte de prima reîncercare (recomandat: 500)"

msgctxt "SettingsOptions::sphinx_holidays::api_retry_multiplier"
msgid "Retry delay multiplier"
msgstr "Multiplicator întârziere reîncercare"

msgctxt "SettingsTooltips::sphinx_holidays::api_retry_multiplier"
msgid "Exponential backoff multiplier for retries (recommended: 2)"
msgstr "Multiplicator exponențial pentru reîncercări (recomandat: 2)"

msgctxt "SettingsOptions::sphinx_holidays::circuit_breaker_threshold"
msgid "Circuit breaker threshold (failures before open)"
msgstr "Prag circuit breaker (eșecuri înainte de deschidere)"

msgctxt "SettingsTooltips::sphinx_holidays::circuit_breaker_threshold"
msgid "Number of consecutive failures before circuit opens and stops API calls"
msgstr "Numărul de eșecuri consecutive înainte de deschiderea circuitului și oprirea apelurilor API"

msgctxt "SettingsOptions::sphinx_holidays::circuit_breaker_timeout"
msgid "Circuit breaker timeout (seconds)"
msgstr "Timeout circuit breaker (secunde)"

msgctxt "SettingsTooltips::sphinx_holidays::circuit_breaker_timeout"
msgid "Seconds to wait before retrying after circuit opens"
msgstr "Secunde de așteptare înainte de reîncercare după deschiderea circuitului"

msgctxt "SettingsOptions::sphinx_holidays::cron_header"
msgid "Cron Settings"
msgstr "Setări Cron"

msgctxt "SettingsOptions::sphinx_holidays::cron_access_key"
msgid "Cron access key (URL: index.php?dispatch=sphinx_cron.run&access_key=KEY&mode=hotels)"
msgstr "Cheie acces cron (URL: index.php?dispatch=sphinx_cron.run&access_key=KEY&mode=hotels)"

msgctxt "SettingsOptions::sphinx_holidays::debug_header"
msgid "Debug"
msgstr "Depanare"

msgctxt "SettingsOptions::sphinx_holidays::debug_logging"
msgid "Enable debug logging"
msgstr "Activează logare depanare"

msgctxt "Languages::sphinx_holidays.relink_existing_products"
msgid "Re-link Existing Products"
msgstr "Reconectează produsele existente"

msgctxt "Languages::sphinx_holidays.relink_confirm"
msgid "This will fetch hotel data from the Sphinx API for all existing SPX products and re-link them. This may take several minutes. Continue?"
msgstr "Se vor prelua datele hotelurilor din API-ul Sphinx pentru toate produsele SPX existente și se vor reconecta. Poate dura câteva minute. Continuați?"

msgctxt "Languages::sphinx_holidays.relink_done"
msgid "Re-linked [linked] of [total] products. Already linked: [skipped]. Not found in API: [not_found]. Errors: [errors]."
msgstr "Reconectate [linked] din [total] produse. Deja conectate: [skipped]. Negăsite în API: [not_found]. Erori: [errors]."

msgctxt "Languages::sphinx_holidays.no_spx_products"
msgid "No products with SPX codes found in the catalog."
msgstr "Nu s-au găsit produse cu cod SPX în catalog."

msgctxt "SettingsOptions::sphinx_holidays::seo_templates_header"
msgid "SEO Templates"
msgstr "Șabloane SEO"

msgctxt "SettingsOptions::sphinx_holidays::seo_placeholders_info"
msgid "Available Sphinx Placeholders"
msgstr "Placeholder-e Sphinx disponibile"

msgctxt "SettingsOptions::sphinx_holidays::seo_product_name"
msgid "Product name template"
msgstr "Șablon nume produs"

msgctxt "SettingsTooltips::sphinx_holidays::seo_product_name"
msgid "Template for the product name."
msgstr "Șablon pentru numele produsului."

msgctxt "SettingsOptions::sphinx_holidays::seo_page_title"
msgid "Page title template"
msgstr "Șablon titlu pagină"

msgctxt "SettingsTooltips::sphinx_holidays::seo_page_title"
msgid "Template for the HTML page title (SEO)."
msgstr "Șablon pentru titlul paginii HTML (SEO)."

msgctxt "SettingsOptions::sphinx_holidays::seo_meta_description"
msgid "Meta description template"
msgstr "Șablon meta descriere"

msgctxt "SettingsTooltips::sphinx_holidays::seo_meta_description"
msgid "Template for the meta description tag."
msgstr "Șablon pentru tag-ul meta description."

msgctxt "SettingsOptions::sphinx_holidays::seo_meta_keywords"
msgid "Meta keywords template"
msgstr "Șablon meta cuvinte cheie"

msgctxt "SettingsTooltips::sphinx_holidays::seo_meta_keywords"
msgid "Template for the meta keywords tag."
msgstr "Șablon pentru tag-ul meta keywords."

msgctxt "SettingsOptions::sphinx_holidays::seo_name_slug"
msgid "SEO URL slug template"
msgstr "Șablon URL SEO (slug)"

msgctxt "SettingsTooltips::sphinx_holidays::seo_name_slug"
msgid "Template for the SEO-friendly URL slug. Result is automatically sanitized."
msgstr "Șablon pentru slug-ul URL SEO. Rezultatul este sanitizat automat."

msgctxt "SettingsOptions::sphinx_holidays::seo_full_description"
msgid "Full description template (optional)"
msgstr "Șablon descriere completă (opțional)"

msgctxt "SettingsTooltips::sphinx_holidays::seo_full_description"
msgid "Optional template to wrap or replace the API description. Leave empty to use the raw API description as-is."
msgstr "Șablon opțional pentru a înfășura sau înlocui descrierea API. Lăsați gol pentru a folosi descrierea API în forma originală."

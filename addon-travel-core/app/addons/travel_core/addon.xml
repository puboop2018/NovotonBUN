    <queries>
        <!-- Shared feature mapping table: canonical definitions -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:travel_feature_map` (
                `map_id`            INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
                `feature_type`      VARCHAR(50)  NOT NULL COMMENT 'board, room_type, stars, property_type, location',
                `canonical_code`    VARCHAR(100) NOT NULL COMMENT 'AI, DBL, 5, hotel, sunny_beach',
                `display_name_en`   VARCHAR(255) NOT NULL COMMENT 'All Inclusive',
                `display_name_ro`   VARCHAR(255) NOT NULL COMMENT 'All Inclusive',
                `cscart_feature_id` INT          DEFAULT NULL COMMENT 'FK to ?:product_features',
                `cscart_variant_id` INT          DEFAULT NULL COMMENT 'FK to ?:product_feature_variants',
                `geoname_id`        INT          DEFAULT NULL COMMENT 'For auto-matching Sphinx destinations',
                `position`          INT          DEFAULT 0,
                `status`            CHAR(1)      DEFAULT 'A' COMMENT 'A=active, D=disabled',
                UNIQUE KEY `uq_type_code` (`feature_type`, `canonical_code`),
                KEY `idx_feature_type` (`feature_type`),
                KEY `idx_cscart_variant` (`cscart_variant_id`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>

        <!-- Per-API alias translations -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:travel_api_alias` (
                `alias_id`   INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
                `map_id`     INT UNSIGNED NOT NULL COMMENT 'FK to travel_feature_map',
                `api_source` VARCHAR(50)  NOT NULL COMMENT 'novoton, sphinx, eurosite',
                `api_value`  VARCHAR(191) NOT NULL COMMENT 'AI, Mic dejun, ALL INCLUSIVE PLUS',
                `match_type` ENUM('exact','prefix','contains','regex') DEFAULT 'exact',
                UNIQUE KEY `uq_source_value` (`api_source`, `api_value`),
                KEY `idx_map` (`map_id`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>

        <!-- Shared bookings table (provider-agnostic view) -->
        <item>
            CREATE TABLE IF NOT EXISTS `?:travel_bookings` (
                `booking_id`        INT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
                `provider`          VARCHAR(50)  NOT NULL COMMENT 'novoton, sphinx',
                `provider_booking_id` VARCHAR(100) DEFAULT NULL COMMENT 'Provider-specific booking ID',
                `order_id`          INT UNSIGNED DEFAULT NULL COMMENT 'FK to ?:orders',
                `user_id`           INT UNSIGNED DEFAULT NULL COMMENT 'FK to ?:users',
                `hotel_id`          VARCHAR(100) NOT NULL,
                `hotel_name`        VARCHAR(255) DEFAULT NULL,
                `destination`       VARCHAR(255) DEFAULT NULL,
                `country_code`      VARCHAR(5)   DEFAULT NULL,
                `check_in`          DATE         NOT NULL,
                `check_out`         DATE         NOT NULL,
                `nights`            TINYINT UNSIGNED NOT NULL,
                `room_name`         VARCHAR(255) DEFAULT NULL,
                `board_code`        VARCHAR(20)  DEFAULT NULL COMMENT 'Canonical board code',
                `adults`            TINYINT UNSIGNED NOT NULL DEFAULT 2,
                `children`          TINYINT UNSIGNED NOT NULL DEFAULT 0,
                `children_ages`     VARCHAR(100) DEFAULT NULL,
                `total_price`       DECIMAL(10,2) NOT NULL,
                `currency`          VARCHAR(5)   NOT NULL DEFAULT 'EUR',
                `status`            VARCHAR(20)  NOT NULL DEFAULT 'pending' COMMENT 'pending, confirmed, cancelled, failed',
                `guests_json`       JSON         DEFAULT NULL COMMENT 'Structured guest data',
                `created_at`        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP,
                `updated_at`        DATETIME     NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
                UNIQUE KEY `uq_provider_booking` (`provider`, `provider_booking_id`),
                KEY `idx_order_id` (`order_id`),
                KEY `idx_status` (`status`),
                KEY `idx_check_in` (`check_in`)
            ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;
        </item>
    </queries>


var/cache/
var/compiled/
var/sticky/
var/tmp/

# IDE / Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Claude Code worktrees (temporary agent sandboxes)
.claude/

# Package Managers
vendor/
node_modules/

# QA tool caches and reports (PHPStan, Psalm, PHP CS Fixer, PHPUnit)
var/
phpcs.cache
.phpunit.result.cache
.php-cs-fixer.cache


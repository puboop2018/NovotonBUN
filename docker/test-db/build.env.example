# Maintainer-local config for docker/test-db/build.sh.
#
# 1. Copy this file to `build.env` in the same directory.
# 2. Edit the paths/keys to match your machine.
# 3. `build.env` is gitignored — it never leaves your machine.
#
# Path notes by shell:
#   - Git Bash:    /c/GitRepoNovotonSphinx/cscart_v4.20.1
#   - WSL:         /mnt/c/GitRepoNovotonSphinx/cscart_v4.20.1
#   - Linux/macOS: /home/you/cscart_v4.20.1  or  /Users/you/cscart_v4.20.1.zip
#
# CSCART_SRC can point at either a .zip archive OR an already-extracted
# directory — build.sh auto-detects.

CSCART_SRC="/c/GitRepoNovotonSphinx/cscart_v4.20.1"
CSCART_LICENSE_KEY="REPLACE_WITH_YOUR_LICENSE_KEY"

# Optional overrides:
# IMAGE_BASE="ghcr.io/puboop2018/novotonbun-test-db"
# CSCART_VERSION="4.20.1"
# SKIP_PUSH="0"

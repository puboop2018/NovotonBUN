msgctxt "Languages::novoton_holidays.how_it_works_step2"
msgid "Extracts rates for EUR, USD, GBP (relative to RON)"
msgstr "Extrage cursurile pentru EUR, USD, GBP (relative la RON)"

msgctxt "Languages::novoton_holidays.how_it_works_step3"
msgid "Calculates EUR-based coefficients and applies commission"
msgstr "Calculează coeficienții bazați pe EUR și aplică comisionul"

msgctxt "Languages::novoton_holidays.how_it_works_step4"

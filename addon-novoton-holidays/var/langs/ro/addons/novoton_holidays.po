msgid "Price higher alert threshold (%)"
msgstr "Prag alertă preț mai mare (%)"

msgctxt "SettingsTooltips::novoton_holidays::price_higher_threshold"
msgid "If the form price exceeds the API price by more than this percentage, the order is still allowed but an admin email notification is sent. Default: 55%."
msgstr "Dacă prețul din formular depășește prețul API cu mai mult decât acest procent, comanda este permisă dar se trimite o notificare email către admin. Implicit: 55%."

msgctxt "SettingsOptions::novoton_holidays::preorder_cache_ttl"

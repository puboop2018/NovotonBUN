<?xml version="1.0" encoding="UTF-8"?>
<!--
  PHPUnit config for the DB-backed integration testsuite.

  Deliberately separate from phpunit.xml because the two testsuites need
  different bootstraps: unit tests load no-op db_* stubs; integration tests
  load real PDO-backed db_* that open a connection from DB_DSN/DB_USER/DB_PASS.
  Merging them into a single config would force unit tests to require a DB
  (or force integration tests to silently no-op DB calls).

  Run with:
    DB_DSN='mysql:host=127.0.0.1;port=3307;dbname=cscart' \
    DB_USER=cscart DB_PASS=cscart \
    vendor/bin/phpunit -c phpunit-integration.xml
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/Integration/bootstrap_integration.php"
         colors="true"
         cacheDirectory=".phpunit.cache.integration"
         failOnRisky="true"
         failOnWarning="true">
    <testsuites>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
            <exclude>tests/Integration/IntegrationTestCase.php</exclude>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>src</directory>
        </include>
    </source>
</phpunit>

<?xml version="1.0"?>
<ruleset name="NovotonBUN">
    <description>Code style rules for the NovotonBUN monorepo (PSR-12 + PHP 8.3).</description>

    <!-- Paths to analyse -->
    <file>addon-novoton-holidays/app/addons/novoton_holidays/src</file>
    <file>addon-travel-core/app/addons/travel_core/src</file>
    <file>addon-sphinx-holidays/app/addons/sphinx_holidays/src</file>

    <!-- Exclusions -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/var/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- Base: PSR-12 (includes PSR-1 + PSR-2) -->
    <rule ref="PSR12">
        <!-- Line length: PSR-12 recommends 120 chars. Legacy code has long lines,
             keep as warning (not error) so it doesn't break CI. -->
        <exclude name="Generic.Files.LineLength"/>

        <!-- File header ordering: we put declare(strict_types=1) BEFORE the
             docblock (the tests and the rest of the codebase have adopted this
             style). PSR-12 wants the docblock first. Keeping current style for
             consistency rather than rewriting 110 file headers. -->
        <exclude name="PSR12.Files.FileHeader.IncorrectOrder"/>
    </rule>

    <!-- Allow files with intentional side effects:
         - HotelSync.php: namespace-level `use` imports
         - Services/ServiceLoader.php: CS-Cart BOOTSTRAP guard required on every
           procedural-helper file before the global function declarations -->
    <rule ref="PSR1.Files.SideEffects">
        <exclude-pattern>*/src/HotelSync.php</exclude-pattern>
        <exclude-pattern>*/src/Services/ServiceLoader.php</exclude-pattern>
    </rule>

    <!-- Line length: warning only, 160 chars -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="160"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
        <severity>4</severity>
    </rule>

    <!-- Show sniff names in output so violations can be easily targeted -->
    <arg value="sp"/>
    <arg name="colors"/>
    <arg name="extensions" value="php"/>
    <arg name="parallel" value="4"/>

    <!-- Only error (severity>=5) fails CI; warnings are informational -->
    <config name="error_severity" value="5"/>
    <config name="warning_severity" value="5"/>
</ruleset>
